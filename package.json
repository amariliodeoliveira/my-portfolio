{
  "name": "my-portfolio",
  "version": "1.1.2",
  "description": "Personal portfolio website of Amarilio de Oliveira, showcasing software development projects with Next.js, React, and TypeScript",
  "author": "Amarilio de Oliveira",
  "homepage": "https://amarilio.tech",
  "repository": "https://github.com/amariliodeoliveira/my-portfolio",
  "keywords": [
    "portfolio",
    "nextjs",
    "react",
    "typescript",
    "software-developer"
  ],
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run type-check && npm run format:check && npm run lint",
    "prepare": "husky",
    "postbuild": "node -e \"import('aeo.js/next').then(m => m.postBuild({ title: 'My Site', url: 'process.env.NEXT_PUBLIC_SITE_URL' }))\""
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "aeo.js": "^0.0.12",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "schema-dts": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.4",
    "@iconify/react": "^6.0.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "daisyui": "^5.5.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.0.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "volta": {
    "node": "24.15.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  }
}
